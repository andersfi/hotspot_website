---
import type { Publication } from "../lib/nva.ts";

interface Props {
  publications: Publication[];
  emptyMessage?: string;
  errorMessage?: string;
  hasError?: boolean;
}

const {
  publications,
  emptyMessage = "No publications found.",
  errorMessage = "Could not fetch publications. Try reloading.",
  hasError = false,
} = Astro.props;
---

{hasError && (
  <div class="fetch-error">{errorMessage}</div>
)}

{!hasError && publications.length === 0 && (
  <p style="color:var(--text-muted)">{emptyMessage}</p>
)}

{publications.length > 0 && (
  <div class="pub-list">
    {publications.map((pub) => (
      <a
        href={pub.url || "#"}
        class="pub-item"
        target={pub.url ? "_blank" : undefined}
        rel={pub.url ? "noopener noreferrer" : undefined}
      >
        <div class="pub-body">
          <div class="pub-title">{pub.title}</div>
          <div class="pub-meta">
            <span class="pub-year">{pub.year}</span>
            {pub.authors && <span>{pub.authors} · </span>}
            <em>{pub.source || "—"}</em>
          </div>
        </div>
        {pub.url && (
          <div class="pub-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
          </div>
        )}
      </a>
    ))}
  </div>
)}

<style>
.fetch-error {
  background: #fff3cd;
  border: 1px solid #ffc107;
  border-radius: 6px;
  padding: 1rem 1.25rem;
  color: #856404;
  margin-bottom: 1.5rem;
  font-size: 0.92rem;
}
</style>
