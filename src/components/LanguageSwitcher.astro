---
interface Props {
  lang: "no" | "en";
  page: string; // activePage key: "om" | "folk" | "kodebase" | "kart" | "publikasjonar"
}

const { lang, page } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Map page key → URL slug (index has no slug)
const slug = page === "om" ? "" : `${page}/`;

const noUrl = `${base}/no/${slug}`;
const enUrl = `${base}/en/${slug}`;
---

<div class="lang-switcher" aria-label="Vel språk">
  <a
    href={noUrl}
    class={lang === "no" ? "lang-btn lang-btn--active" : "lang-btn"}
    aria-current={lang === "no" ? "true" : undefined}
    hreflang="nn"
  >NO</a>
  <span class="lang-sep" aria-hidden="true">|</span>
  <a
    href={enUrl}
    class={lang === "en" ? "lang-btn lang-btn--active" : "lang-btn"}
    aria-current={lang === "en" ? "true" : undefined}
    hreflang="en"
  >EN</a>
</div>

<style>
.lang-switcher {
  display: flex;
  align-items: center;
  gap: 0.3rem;
  margin-left: 1.25rem;
  flex-shrink: 0;
}

.lang-sep {
  color: var(--border);
  font-size: 0.8rem;
}

.lang-btn {
  font-size: 0.78rem;
  font-weight: 500;
  text-decoration: none;
  color: var(--text-muted);
  letter-spacing: 0.05em;
  padding: 0.2rem 0.1rem;
  transition: color 0.15s;
}

.lang-btn:hover {
  color: var(--green);
}

.lang-btn--active {
  font-weight: 700;
  color: var(--green-dark);
}
</style>
