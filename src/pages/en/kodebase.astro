---
import Layout from "../../layouts/Layout.astro";
import RepoCard from "../../components/RepoCard.astro";
import { readFileSync } from "fs";
import { join } from "path";
import yaml from "js-yaml";

interface RepoEntry {
  name: string;
  url: string;
  description: { no: string; en: string };
}

const repos = yaml.load(
  readFileSync(join(process.cwd(), "src/data/repositories.yaml"), "utf-8")
) as RepoEntry[];
---

<Layout title="Codebase" activePage="kodebase" lang="en">
  <div class="page-header">
    <div class="page-header-inner">
      <h1>Codebase</h1>
      <p>Open source code from the Hotspots projects, available on GitHub.</p>
    </div>
  </div>

  <div class="section">
    <div class="repo-list">
      {repos.map(repo => (
        <RepoCard
          name={repo.name}
          url={repo.url}
          description={repo.description.en}
          linkLabel="View on GitHub"
        />
      ))}
    </div>
  </div>
</Layout>

<style>
.repo-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.25rem; }
</style>
