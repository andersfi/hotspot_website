---
import Layout from "../../layouts/Layout.astro";
import PublicationList from "../../components/PublicationList.astro";
import { config } from "../../lib/config.ts";
import { fetchPublications } from "../../lib/nva.ts";

const { cristin_project_id } = config.nva;

const publications = await fetchPublications(cristin_project_id);
const fetchError = publications.length === 0;
---

<Layout title="Publications" activePage="publikasjonar" lang="en">
  <div class="page-header">
    <div class="page-header-inner">
      <h1>Publications</h1>
      <p>
        Reports, notes and datasets from the Hotspots project. Fetched automatically from
        <a href={`https://nva.sikt.no/projects/${cristin_project_id}`} target="_blank" rel="noopener" style="color:var(--green)">NVA</a>.
      </p>
    </div>
  </div>

  <div class="section">
    <PublicationList
      publications={publications}
      hasError={fetchError}
      emptyMessage="No publications found."
      errorMessage="Could not fetch publications from NVA right now. Try reloading the page."
    />
  </div>
</Layout>
