---
import Layout from "../../layouts/Layout.astro";
import ToolCard from "../../components/ToolCard.astro";
import { readFileSync } from "fs";
import { join } from "path";
import yaml from "js-yaml";

interface ToolEntry {
  id: string;
  title: { no: string; en: string };
  description: { no: string; en: string };
  iframe_src: string;
}

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const tools = yaml.load(
  readFileSync(join(process.cwd(), "src/data/tools.yaml"), "utf-8")
) as ToolEntry[];
---

<Layout title="Utforsk" activePage="kart" lang="no">
  <div class="page-header">
    <div class="page-header-inner">
      <h1>Utforsk</h1>
      <p>Interaktive døme på heildekkande kart over artsmangfald frå Hotspot-prosjektene.</p>
    </div>
  </div>

  <div class="section">
    <div class="map-list">
      {tools.map(tool => (
        <ToolCard
          title={tool.title.no}
          description={tool.description.no}
          iframeSrc={`${base}${tool.iframe_src}`}
        />
      ))}
    </div>
  </div>
</Layout>

<style>
.map-list { display: flex; flex-direction: column; gap: 2.5rem; }
</style>
