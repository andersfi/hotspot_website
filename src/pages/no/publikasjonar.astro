---
import Layout from "../../layouts/Layout.astro";
import PublicationList from "../../components/PublicationList.astro";
import { config } from "../../lib/config.ts";
import { fetchPublications } from "../../lib/nva.ts";

const { cristin_project_id } = config.nva;

let publications = await fetchPublications(cristin_project_id);
const fetchError = publications.length === 0;
---

<Layout title="Publikasjonar" activePage="publikasjonar" lang="no">
  <div class="page-header">
    <div class="page-header-inner">
      <h1>Publikasjonar</h1>
      <p>
        Rapportar, notat og datasett frå Hotspot-prosjektene. Henta automatisk frå
        <a href={`https://nva.sikt.no/projects/${cristin_project_id}`} target="_blank" rel="noopener" style="color:var(--green)">NVA</a>.
      </p>
    </div>
  </div>

  <div class="section">
    <PublicationList
      publications={publications}
      hasError={fetchError}
      emptyMessage="Ingen publikasjonar funne."
      errorMessage="Kunne ikkje hente publikasjonar frå NVA akkurat no. Prøv å laste sida på nytt."
    />
  </div>
</Layout>
