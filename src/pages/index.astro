---
// Redirect to Norwegian (default language)
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0;url=${base}/no/`} />
    <link rel="canonical" href={`${base}/no/`} />
    <title>Hotspots</title>
  </head>
  <body>
    <p><a href={`${base}/no/`}>Går til norsk versjon…</a></p>
  </body>
</html>
