---
import Layout from "../layouts/Layout.astro";
import tools from "../data/tools.json";
---

<Layout title="Verktøy" activePage="verktoy">
  <div class="page-header">
    <div class="page-header-inner">
      <h1>Verktøy og ressursar</h1>
      <p>Interaktive kart, open kjeldekode og datakjelder frå Hotspot-prosjektet.</p>
    </div>
  </div>

  <div class="section">
    <div class="tool-list">
      {tools.map(tool => (
        <div class="tool-card">
          <div class="tool-card-body">
            <div class="tool-title">{tool.title}</div>
            <p class="tool-desc">{tool.desc || tool.description}</p>
            {tool.type === "external" && tool.url && (
              <a href={tool.url} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                Opne
              </a>
            )}
          </div>
          {tool.type === "map" && tool.mapSrc && (
            <iframe
              src={tool.mapSrc}
              class="tool-map"
              title={tool.title}
              loading="lazy"
              sandbox="allow-scripts allow-same-origin"
            ></iframe>
          )}
        </div>
      ))}
    </div>
  </div>
</Layout>
